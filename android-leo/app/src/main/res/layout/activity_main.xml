<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <!-- ══ HEADER ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:background="#0A0A0A">

        <ImageView
            android:id="@+id/imgLeoLogo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Leo"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <!-- Dynamic agent name (set from SecurityManager) -->
            <TextView
                android:id="@+id/tvAgentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEO"
                android:textColor="#00E5FF"
                android:textSize="20sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHS LAB — ReAct APEX Engine"
                android:textColor="#E91E8C"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1" />

        </LinearLayout>

        <!-- Surveillance button -->
        <Button
            android:id="@+id/btnSurveillance"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="WATCH"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#00E5FF"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="5dp" />

        <!-- Vault button -->
        <Button
            android:id="@+id/btnVault"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="⚙ VAULT"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#6B35A5"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="5dp" />

        <!-- Island button -->
        <Button
            android:id="@+id/btnIsland"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="HUD"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#FFD600"
            android:paddingHorizontal="8dp" />

    </LinearLayout>

    <!-- ══ PERMISSION STATUS BAR ══ -->
    <LinearLayout
        android:id="@+id/layoutPermissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D0D0D"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/dotAccessibility"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/status_dot" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Accessibility"
            android:textColor="#666666"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp" />

        <Button
            android:id="@+id/btnEnableAccessibility"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text="ENABLE"
            android:textSize="7sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#FF4444"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="10dp" />

        <View
            android:id="@+id/dotOverlay"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/status_dot" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Overlay"
            android:textColor="#666666"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp" />

        <Button
            android:id="@+id/btnEnableOverlay"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text="ENABLE"
            android:textSize="7sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#FF4444"
            android:paddingHorizontal="8dp" />

    </LinearLayout>

    <!-- ══ DIVIDER ══ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#1A1A1A" />

    <!-- ══ CHAT RECYCLER ══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        android:paddingVertical="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbars="none" />

    <!-- ══ DIVIDER ══ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#1A1A1A" />

    <!-- ══ INPUT BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#080808"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical">

        <!-- MIC button for voice input -->
        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="#111111"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Voice input"
            android:layout_marginEnd="6dp" />

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/input_background"
            android:textColor="#00E5FF"
            android:textColorHint="#334455"
            android:hint="give Leo a mission..."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingHorizontal="10dp"
            android:inputType="text"
            android:imeOptions="actionSend"
            android:maxLines="1"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="GO"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#E91E8C"
            android:paddingHorizontal="16dp"
            android:layout_marginStart="8dp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
