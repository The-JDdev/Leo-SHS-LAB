<?xml version="1.0" encoding="utf-8"?>
<!--
    LEO TERMINAL UI — SHS LAB
    Pitch-black God-Mode Command Interface
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- ══ HEADER: LOGO + BRAND ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="#0A0A0A">

        <ImageView
            android:id="@+id/imgLeoLogo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Leo Logo"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEO"
                android:textColor="#00E5FF"
                android:textSize="22sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHS LAB — System Agent v1.0"
                android:textColor="#E91E8C"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15" />
        </LinearLayout>

        <!-- Overlay toggle button -->
        <Button
            android:id="@+id/btnOverlay"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="ISLAND"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#FFD600"
            android:letterSpacing="0.15"
            android:paddingHorizontal="10dp" />

    </LinearLayout>

    <!-- ══ DIVIDER ══ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#1A1A1A" />

    <!-- ══ TERMINAL LOG: ScrollView + TextView ══ -->
    <ScrollView
        android:id="@+id/scrollTerminal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        android:fillViewport="true"
        android:fadeScrollbars="true"
        android:scrollbarThumbVertical="@color/cyan"
        android:overScrollMode="never">

        <TextView
            android:id="@+id/tvTerminal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textColor="#00E5FF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.4"
            android:text=""
            android:textIsSelectable="true"
            android:keepScreenOn="true" />

    </ScrollView>

    <!-- ══ DIVIDER ══ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#1E1E1E" />

    <!-- ══ INPUT BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#080808"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❯"
            android:textColor="#E91E8C"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:paddingEnd="6dp" />

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/input_background"
            android:textColor="#00E5FF"
            android:textColorHint="#334455"
            android:hint="enter command..."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingHorizontal="10dp"
            android:inputType="text"
            android:imeOptions="actionSend"
            android:maxLines="1"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="RUN"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#E91E8C"
            android:letterSpacing="0.1"
            android:paddingHorizontal="14dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
