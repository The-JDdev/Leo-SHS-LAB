<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <!-- ══ HEADER ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="#0A0A0A">

        <ImageView
            android:id="@+id/imgLeoLogo"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Leo"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEO"
                android:textColor="#00E5FF"
                android:textSize="22sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHS LAB — Limitless Android Surrogate"
                android:textColor="#E91E8C"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1" />

        </LinearLayout>

        <!-- Vault button -->
        <Button
            android:id="@+id/btnVault"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="⚙ VAULT"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#6B35A5"
            android:paddingHorizontal="10dp"
            android:layout_marginEnd="6dp" />

        <!-- Island button -->
        <Button
            android:id="@+id/btnIsland"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="ISLAND"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#FFD600"
            android:paddingHorizontal="10dp" />

    </LinearLayout>

    <!-- ══ PERMISSION STATUS BAR ══ -->
    <LinearLayout
        android:id="@+id/layoutPermissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D0D0D"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/dotAccessibility"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/status_dot" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Accessibility"
            android:textColor="#888888"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:paddingStart="8dp" />

        <Button
            android:id="@+id/btnEnableAccessibility"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="ENABLE"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#FF4444"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="12dp" />

        <View
            android:id="@+id/dotOverlay"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/status_dot" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Overlay"
            android:textColor="#888888"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:paddingStart="8dp" />

        <Button
            android:id="@+id/btnEnableOverlay"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="ENABLE"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#FF4444"
            android:paddingHorizontal="8dp" />

    </LinearLayout>

    <!-- ══ DIVIDER ══ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#1A1A1A" />

    <!-- ══ CHAT RECYCLER ══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        android:paddingVertical="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbars="none" />

    <!-- ══ DIVIDER ══ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#1A1A1A" />

    <!-- ══ INPUT BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#080808"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❯"
            android:textColor="#E91E8C"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:paddingEnd="6dp" />

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/input_background"
            android:textColor="#00E5FF"
            android:textColorHint="#334455"
            android:hint="message Leo..."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingHorizontal="10dp"
            android:inputType="text"
            android:imeOptions="actionSend"
            android:maxLines="1"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="SEND"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#000000"
            android:backgroundTint="#E91E8C"
            android:paddingHorizontal="14dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
