<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="6dp"
    android:gravity="top">

    <!-- Leo Avatar: "L" circle in cyan -->
    <TextView
        android:id="@+id/tvLeoAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="L"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:background="@drawable/avatar_leo"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp" />

    <!-- Right column: thinking block + message -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- ══ THINKING ACCORDION ══ -->
        <LinearLayout
            android:id="@+id/layoutThinking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/thinking_bg"
            android:layout_marginBottom="4dp">

            <!-- Clickable header -->
            <TextView
                android:id="@+id/tvThinkingHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▶  Thinking..."
                android:textColor="#FFD600"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <!-- Collapsible log body (GONE by default) -->
            <TextView
                android:id="@+id/tvThinkingLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textColor="#888888"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:paddingHorizontal="10dp"
                android:paddingBottom="8dp"
                android:maxLines="40"
                android:scrollbars="vertical" />

        </LinearLayout>

        <!-- ══ LEO RESPONSE BUBBLE ══ -->
        <TextView
            android:id="@+id/tvLeoMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="260dp"
            android:background="@drawable/bubble_leo"
            android:textColor="#00E5FF"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:lineSpacingMultiplier="1.3"
            android:textIsSelectable="true"
            android:visibility="gone" />

        <!-- Timestamp below bubble -->
        <TextView
            android:id="@+id/tvLeoTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#333333"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:paddingTop="2dp" />

    </LinearLayout>

</LinearLayout>
