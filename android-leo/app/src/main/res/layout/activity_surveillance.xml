<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- ══ HEADER ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0A0A0A"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LEO SURVEILLANCE"
            android:textColor="#00E5FF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.2" />

        <!-- Toggle: Browser | Terminal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Browser"
            android:textColor="#888888"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="4dp" />

        <Switch
            android:id="@+id/switchPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:thumbTint="#00E5FF"
            android:trackTint="#222222" />

    </LinearLayout>

    <!-- ══ CURRENT URL BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D0D0D"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="URL: "
            android:textColor="#E91E8C"
            android:textSize="9sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvCurrentUrl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="about:blank"
            android:textColor="#00E5FF"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="middle" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#1A1A1A" />

    <!-- ══ BROWSER WEBVIEW (top panel) ══ -->
    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#050505"
        android:visibility="visible" />

    <!-- ══ TERMINAL LOG (bottom panel, toggled) ══ -->
    <ScrollView
        android:id="@+id/scrollTerminal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#030303"
        android:visibility="gone"
        android:padding="8dp"
        android:overScrollMode="never">

        <TextView
            android:id="@+id/tvTerminalLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#00E5FF"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.3" />

    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#1A1A1A" />

    <!-- ══ STATUS FOOTER ══ -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Leo's inbuilt browser and terminal — watching silently so JD can monitor missions in real-time."
        android:textColor="#333333"
        android:textSize="8sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:padding="8dp"
        android:background="#050505" />

</LinearLayout>
